# ── Supabase ── get these from supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic ──
ANTHROPIC_API_KEY=

# ── OpenAI (Whisper transcription) ──
OPENAI_API_KEY=

# ── App secrets ──
CRON_SECRET=
INTERNAL_API_SECRET=

# ── App URL ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── CORE integration (student-side app) ──
# Base URL for the CORE student app (used by the CORE sync "open student"
# link on candidate-detail). Falls back to https://app.inteliflowai.com
# if unset. Leave blank for dev; set to your CORE prod URL in production.
NEXT_PUBLIC_CORE_URL=

# ── SMTP Email ──
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=

# ── Google Classroom (optional) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
